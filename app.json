{
  "expo": {
    "name": "Kalender Jawa",
    "slug": "kalender_jawa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-wayang.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A120B"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.anonymous.kalender_jawa",
      "jsEngine": "hermes",
      "enableProguardInReleaseBuilds": true,
      "enableHermesOptimizations": true
    },
    "web": {
      "favicon": "./assets/icon-wayang.png"
    },
    "extra": {
      "eas": {
        "projectId": "3926df7b-1add-4f64-b73c-483f9ba8f380"
      }
    }
  }
}
